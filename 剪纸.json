    "发展历程": [
      {
        "朝代": "先秦",
        "时期": "萌芽期",
        "描述": "在纸张出现之前，人们运用金箔、皮革、绢帛、树叶等薄片材料，通过雕、镂、剔、刻、剪的技法制作工艺品。《史记》记载西周初期周成王'剪桐封弟'的故事，用梧桐叶剪成'圭'形，这被认为是剪纸艺术的雏形。"
      },
      {
        "朝代": "西汉",
        "时期": "起源期",
        "描述": "纸的发明为剪纸的出现创造了条件。1934年陕西宝鸡西汉墓出土'交股式'铁剪，为剪纸艺术提供了实物证据。"
      },
      {
        "朝代": "南北朝",
        "时期": "成熟期",
        "描述": "新疆吐鲁番火焰山附近出土北朝时期的《对马》《对猴》《忍冬纹》《菊花纹》《几何纹》五幅团花剪纸，这是目前发现的最早剪纸实物，距今已有1500多年历史。"
      },
      {
        "朝代": "唐代",
        "时期": "发展期",
        "描述": "唐代剪纸处于大发展时期，技艺更加精湛，题材更加丰富多样。杜甫《彭衙行》诗中有'暖汤濯我足，翦纸招我魂'的句子，说明剪纸招魂风俗已流传民间。唐代还出现利用剪纸形式制作的漏版印花板。"
      },
      {
        "朝代": "宋代",
        "时期": "繁荣期",
        "描述": "宋代造纸业成熟，纸张种类繁多，为剪纸的普及提供了物质条件。南宋时期出现专业民间剪纸艺人，《东京梦华录》中有'剪彩为花，镂金作胜'的记载。"
      },
      {
        "朝代": "明清",
        "时期": "鼎盛期",
        "描述": "明清时期剪纸艺术达到鼎盛，成为全民艺术。剪纸走入宫廷，清代皇帝大婚婚房墙壁四角贴双喜字剪纸角花，顶棚中心贴龙凤团花。民间剪纸广泛应用于岁时节令、婚丧嫁娶等各个方面。"
      },
      {
        "朝代": "现代",
        "时期": "保护期",
        "描述": "2006年剪纸列入第一批国家级非物质文化遗产名录，2009年作为中国剪纸的重要组成部分入选联合国教科文组织人类非物质文化遗产代表作名录，剪纸艺术得到重视和保护。"
      }
    ],
    "起源传说": [
      {
        "名称": "剪桐封弟",
        "内容": "《史记》记载，西周初期周成王与弟弟姬虞玩耍，用梧桐叶剪成'圭'形赐给姬虞，封他到唐地为侯。这被认为是剪纸艺术的最早雏形。"
      },
      {
        "名称": "李夫人招魂",
        "内容": "相传汉武帝爱妃李夫人病逝，方士李少翁用棉帛裁成李夫人影像，涂上色彩，在灯光下投影于帐幕，汉武帝远远望去，仿佛爱妃复活。这虽然是皮影戏的雏形，但也体现了剪纸艺术的原理。"
      }
    ]
